<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="https://github.com/avaloniaui/designer"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="client.Views.FencingScoreboardView">

    <Grid x:Name="MainGrid" Background="#2C2C2C" RowDefinitions="Auto,*,Auto,Auto" ColumnDefinitions="*,*">
        <!-- Full-Screen Overlay -->
        <Border x:Name="OverlayPanel" Background="Transparent" IsVisible="False" Grid.RowSpan="4" Grid.ColumnSpan="2">
        </Border>

        <!-- Timer -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   x:Name="TimerText"
                   FontSize="72"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   PointerPressed="OnTimerClick" />

        <!-- Fencer 1 -->
        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="20" HorizontalAlignment="Center">
            <TextBlock Text="Fencer 1"
                       FontSize="24"
                       Foreground="White"
                       HorizontalAlignment="Center" />
            <Border Background="#4CAF50" CornerRadius="20" Padding="30">
                <TextBlock x:Name="Fencer1Score" 
                           FontSize="48"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
            <StackPanel Orientation="Horizontal" Spacing="20">
                <Button Content="+"
                        Background="#4CAF50"
                        Foreground="White"
                        FontSize="48"
                        CornerRadius="50"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Width="100"
                        Height="100"
                        Click="OnFencer1AddScore" />
                <Button Content="-"
                        Background="#F44336"
                        Foreground="White"
                        FontSize="48"
                        CornerRadius="50"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Width="100"
                        Height="100"
                        Click="OnFencer1SubtractScore" />
            </StackPanel>
        </StackPanel>

        <!-- Fencer 2 -->
        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="20" HorizontalAlignment="Center">
            <TextBlock Text="Fencer 2"
                       FontSize="24"
                       Foreground="White"
                       HorizontalAlignment="Center" />
            <Border Background="#F44336" CornerRadius="20" Padding="30">
                <TextBlock x:Name="Fencer2Score" 
                           FontSize="48"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
            <StackPanel Orientation="Horizontal" Spacing="20">
                <Button Content="+"
                        Background="#4CAF50"
                        Foreground="White"
                        FontSize="48"
                        CornerRadius="50"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Width="100"
                        Height="100"
                        Click="OnFencer1AddScore" />
                <Button Content="-"
                        Background="#F44336"
                        Foreground="White"
                        FontSize="48"
                        CornerRadius="50"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Width="100"
                        Height="100"
                        Click="OnFencer1SubtractScore" />
            </StackPanel>
        </StackPanel>

        <!-- Double Button -->
        <Button Grid.Row="2" Grid.ColumnSpan="2"
                Content="Double!"
                Background="#3F51B5"
                Foreground="White"
                FontSize="36"
                CornerRadius="40"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0,20,0,20"
                Click="OnDouble" />

        <!-- Card Buttons -->
        <Grid Grid.Row="3" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20" ColumnDefinitions="*,*,*">
            <Button Content="Yellow Card"
                    Grid.Column="0"
                    Background="Yellow"
                    Foreground="Black"
                    FontSize="20"
                    CornerRadius="40"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Padding="10"
                    Width="200"
                    Height="80"
                    Click="OnYellowCardClick" />
            <Button Content="Red Card"
                    Grid.Column="1"
                    Background="Red"
                    Foreground="White"
                    FontSize="20"
                    CornerRadius="40"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Padding="10"
                    Width="200"
                    Height="80"
                    Click="OnRedCardClick" />
            <Button Content="Black Card"
                    Grid.Column="2"
                    Background="Black"
                    Foreground="White"
                    FontSize="20"
                    CornerRadius="40"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Padding="10"
                    Width="200"
                    Height="80"
                    Click="OnBlackCardClick" />
        </Grid>



    </Grid>
</UserControl>
